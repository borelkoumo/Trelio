# Supabase Configuration
# Get these from your Vercel Supabase integration or Supabase project dashboard.
NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_URL"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# Demo account — credentials shown on the merchant login page for easy access.
# These are intentionally public (NEXT_PUBLIC_) since they belong to a sandboxed demo merchant.
# Leave blank to hide the demo panel entirely.
NEXT_PUBLIC_DEMO_EMAIL="demo@trelio.io"
NEXT_PUBLIC_DEMO_PASSWORD="demo1234"
# UUID of the demo merchant row in the merchants table.
# The "Open customer view" link on the QR display page is shown for this merchant in production
# (and for all merchants on localhost automatically).
NEXT_PUBLIC_DEMO_MERCHANT_ID="your-demo-merchant-uuid"

# APP_URL is no longer needed — Vercel injects NEXT_PUBLIC_VERCEL_URL automatically.
# For local dev the app falls back to http://localhost:3000.
